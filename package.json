{
    "name": "iobroker.matter",
    "version": "1.2.1",
    "description": "Controlling and simulation of matter devices",
    "author": {
        "name": "Denis Haev",
        "email": "dogafox@gmail.com"
    },
    "contributors": [
        "Apollon77 <matter@fischer-ka.de>",
        "foxriver76 <moritz.heusinger@gmail.com>"
    ],
    "homepage": "https://github.com/ioBroker/ioBroker.matter",
    "keywords": [
        "ioBroker",
        "matter"
    ],
    "engines": {
        "node": ">=20"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/ioBroker/ioBroker.matter"
    },
    "optionalDependencies": {
        "@matter/nodejs-ble": "0.17.7-alpha.0-20260716-1a7047cc7"
    },
    "dependencies": {
        "@iobroker/adapter-core": "^3.4.3",
        "@iobroker/dm-utils": "^3.1.3",
        "@iobroker/type-detector": "^5.0.15",
        "@matter/main": "0.17.7-alpha.0-20260716-1a7047cc7",
        "@matter/nodejs": "0.17.7-alpha.0-20260716-1a7047cc7",
        "@project-chip/matter.js": "0.17.7-alpha.0-20260716-1a7047cc7",
        "axios": "^1.18.1",
        "jsonwebtoken": "^9.0.3"
    },
    "devDependencies": {
        "@alcalzone/release-script": "^5.2.1",
        "@alcalzone/release-script-plugin-iobroker": "^5.2.0",
        "@alcalzone/release-script-plugin-license": "^5.2.0",
        "@iobroker/adapter-dev": "^1.5.0",
        "@iobroker/build-tools": "^3.0.1",
        "@iobroker/dev-server": "^0.8.0",
        "@iobroker/eslint-config": "^2.3.4",
        "@iobroker/legacy-testing": "^2.1.2",
        "@iobroker/testing": "^5.3.0",
        "@iobroker/types": "^7.2.2",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^22.20.1",
        "colorette": "^2.0.20",
        "cross-env": "^10.1.0",
        "esbuild": "^0.28.1",
        "eslint-plugin-import": "^2.32.0",
        "puppeteer": "^24.43.1",
        "ts-node": "^10.9.2",
        "typescript": "~6.0.3"
    },
    "bugs": {
        "url": "https://github.com/ioBroker/ioBroker.matter/issues"
    },
    "main": "build/main.js",
    "files": [
        "admin/",
        "io-package.json",
        "LICENSE",
        "build/",
        "data/"
    ],
    "scripts": {
        "test": "cross-env TS_NODE_PROJECT=./tsconfig.test.json mocha --exit test/**/*.test.ts",
        "prepublishOnly": "npm run build",
        "npm": "npm i && cd src-admin && npm i",
        "lint": "eslint -c eslint.config.mjs",
        "lint-frontend": "cd src-admin && eslint -c eslint.config.mjs",
        "build": "npm run build:ts && npm run build:gui",
        "build:gui": "node tasks.js --build",
        "build:ts": "tsc -p tsconfig.build.json && node tasks.js --copy-i18n",
        "copy-i18n": "node tasks.js --copy-i18n",
        "release": "release-script",
        "update-packages": "npx -y npm-check-updates --upgrade && cd src-admin && npx -y npm-check-updates --upgrade",
        "dev-server": "dev-server",
        "format": "prettier --write 'src/**/*.ts' 'src-admin/**/*.tsx'",
        "0-clean": "node tasks.js --0-clean",
        "1-npm": "node tasks.js --1-npm",
        "2-build": "node tasks.js --2-build",
        "3-copy": "node tasks.js --3-copy",
        "4-patch": "node tasks.js --4-patch",
        "translate": "translate-adapter"
    },
    "license": "Apache-2.0",
    "readmeFilename": "README.md",
    "allowScripts": {
        "@serialport/bindings-cpp@12.0.1": true,
        "@stoprocent/bleno@0.12.5": true,
        "@stoprocent/bluetooth-hci-socket@2.2.6": true,
        "@stoprocent/noble@2.5.7": true,
        "diskusage@1.2.0": true,
        "fsevents@2.3.3": true,
        "protobufjs@7.6.2": true,
        "puppeteer@24.43.1": true,
        "unix-dgram@2.0.6": true,
        "usb@2.18.0": true,
        "esbuild@0.11.23": true,
        "esbuild@0.25.12": true,
        "esbuild@0.28.1": true
    }
}
